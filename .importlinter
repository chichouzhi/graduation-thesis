[importlinter]
root_package = app
include_external_packages = True

# Canonical spec mapping:
#   forbidden_api_adapter      -> R-API-ADAPTER (+ recommendations subset)
#   forbidden_api_use_cases    -> R-API-UC
#   forbidden_api_task         -> R-API-TASK
#   forbidden_task_api         -> R-TASK-API
#   forbidden_task_adapter     -> R-UC-SKIP / W6
#   forbidden_use_cases_flask  -> R-UC-API
#   forbidden_use_cases_api    -> R-UC-API
#   domain_api_service_layers  -> W1
#   use_cases_over_adapter     -> W5

# Layers: see architecture.spec.md section 4.
# - Per domain: api (high) then service (low): service must not import api.
# - Global: use_cases then adapter: adapter must not import use_cases.
# Higher layers may import lower; API must not reach UC/Adapter via layers alone
#   (use forbidden_api_* contracts).

[importlinter:contract:domain_api_service_layers]
name = Per-domain API over service (matches app/<domain>/api, app/<domain>/service)
type = layers
containers =
    app.identity
    app.terms
    app.taskboard
    app.chat
    app.document
    app.topic
    app.selection
    app.recommendations
layers =
    api
    service

[importlinter:contract:use_cases_over_adapter]
name = use_cases over adapter (orchestration may depend on integrations, not vice versa)
type = layers
layers =
    app.use_cases
    app.adapter

# Forbidden contracts (architecture.spec.md section 4 + R-UC-API).

[importlinter:contract:forbidden_api_adapter]
name = API must not import adapter (R-API-ADAPTER)
type = forbidden
source_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api
forbidden_modules =
    app.adapter
allow_indirect_imports = True

[importlinter:contract:forbidden_api_use_cases]
name = API must not import use_cases (R-API-UC)
type = forbidden
source_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api
forbidden_modules =
    app.use_cases
allow_indirect_imports = True

[importlinter:contract:forbidden_api_task]
name = API must not import task package (R-API-TASK)
type = forbidden
source_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api
forbidden_modules =
    app.task
allow_indirect_imports = True

[importlinter:contract:forbidden_use_cases_flask]
name = use_cases must not import flask (R-UC-API partial)
type = forbidden
source_modules =
    app.use_cases
forbidden_modules =
    flask

[importlinter:contract:forbidden_use_cases_api]
name = use_cases must not import domain API packages (R-UC-API)
type = forbidden
source_modules =
    app.use_cases
forbidden_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api

[importlinter:contract:forbidden_task_api]
name = TASK must not import API layers (R-TASK-API)
type = forbidden
source_modules =
    app.task
forbidden_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api

[importlinter:contract:forbidden_task_adapter]
name = TASK must not import adapter (R-UC-SKIP / W6)
type = forbidden
source_modules =
    app.task
forbidden_modules =
    app.adapter
allow_indirect_imports = True
