[importlinter]
root_package = app

# ---------------------------------------------------------------------------
# Layers（分层结构 → layers 合约）
#
# 1) 每个 bounded context：api（高）→ service（低）。约束「service 不得 import api」。
# 2) 全局：use_cases（高）→ adapter（低）。约束「adapter 不得 import use_cases」；
#    use_cases → adapter 合法（W5）。注意：import-linter 语义为「高层可依赖任意更底层」，
#    故 API 不得直达 UC/Adapter 仍须靠下方 forbidden_api_* 合约（与 architecture.spec §4 一致）。
# ---------------------------------------------------------------------------

[importlinter:contract:domain_api_service_layers]
name = Per-domain API over service (matches app/<domain>/api, app/<domain>/service)
type = layers
containers =
    app.identity
    app.terms
    app.taskboard
    app.chat
    app.document
    app.topic
    app.selection
    app.recommendations
layers =
    api
    service

[importlinter:contract:use_cases_over_adapter]
name = use_cases over adapter (orchestration may depend on integrations, not vice versa)
type = layers
layers =
    app.use_cases
    app.adapter

# ---------------------------------------------------------------------------
# Forbidden contracts（禁止边）— 与 architecture.spec.md §4 对齐并增补
# ---------------------------------------------------------------------------

[importlinter:contract:forbidden_api_adapter]
name = API must not import adapter (R-API-ADAPTER)
type = forbidden
source_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api
forbidden_modules =
    app.adapter

[importlinter:contract:forbidden_api_use_cases]
name = API must not import use_cases (R-API-UC)
type = forbidden
source_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api
forbidden_modules =
    app.use_cases

[importlinter:contract:forbidden_api_task]
name = API must not import task package (R-API-TASK)
type = forbidden
source_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api
forbidden_modules =
    app.task

[importlinter:contract:forbidden_use_cases_flask]
name = use_cases must not import flask (R-UC-API partial)
type = forbidden
source_modules =
    app.use_cases
forbidden_modules =
    flask

[importlinter:contract:forbidden_use_cases_api]
name = use_cases must not import domain API packages (R-UC-API)
type = forbidden
source_modules =
    app.use_cases
forbidden_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api

[importlinter:contract:forbidden_task_api]
name = TASK must not import API layers (R-TASK-API)
type = forbidden
source_modules =
    app.task
forbidden_modules =
    app.identity.api
    app.terms.api
    app.taskboard.api
    app.chat.api
    app.document.api
    app.topic.api
    app.selection.api
    app.recommendations.api

[importlinter:contract:forbidden_task_adapter]
name = TASK must not import adapter (R-UC-SKIP / W6)
type = forbidden
source_modules =
    app.task
forbidden_modules =
    app.adapter
